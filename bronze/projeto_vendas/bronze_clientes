%run /Workspace/home/lib/lib_gerar_tabelas_fake

clientes = []

for i in range(1, n_clientes+1):
    clientes.append({
        "id_cliente": i,
        "nome_cliente": fake.name(),
        "email": fake.email(),
        "telefone": fake.phone_number(),
        "cidade": fake.city(),
        "estado": fake.estado_sigla(),
        "data_cadastro": fake.date_between(start_date='-8y', end_date='today'),
        "segmento": random.choice(["Pessoa Física", "Empresa"])
    })

df_clientes = spark.createDataFrame(clientes)    
df_clientes.write.mode("overwrite").option("overwriteSchema", "true").saveAsTable("workspace.bronze.clientes")
